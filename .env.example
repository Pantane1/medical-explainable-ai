# Application
APP_ENV=development
SECRET_KEY=change-this-to-a-secure-random-key
LOG_LEVEL=INFO

# Database (for audit log persistence)
DATABASE_URL=sqlite:///medical_ai.db

# API
API_HOST=0.0.0.0
API_PORT=5000
API_KEY=your-api-key-here

# Model
DEFAULT_MODEL=decision_tree
MODEL_PATH=models/trained/

# SHAP
SHAP_NUM_FEATURES=8
